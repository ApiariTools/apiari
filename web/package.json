{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,css,json}\"",
    "check": "npm run typecheck && npm run lint && npm run format:check",
    "preview": "vite preview",
    "test:e2e": "playwright test --config playwright.e2e.config.ts",
    "test:chat": "playwright test --config playwright.chat.config.ts",
    "chat:demo": "vite --config packages/chat/vite.config.ts --port 5174 --host 127.0.0.1",
    "ui:demo": "vite --config packages/ui/vite.config.ts --port 5175 --host 127.0.0.1"
  },
  "dependencies": {
    "@apiari/api": "*",
    "@apiari/chat": "*",
    "@apiari/types": "*",
    "@apiari/ui": "*",
    "@git-diff-view/core": "^0.1.3",
    "@git-diff-view/react": "^0.1.3",
    "@ricky0123/vad-web": "^0.0.30",
    "cmdk": "^1.1.1",
    "howler": "^2.2.4",
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/howler": "^2.2.12",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
